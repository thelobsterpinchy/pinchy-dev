{
  "name": "pinchy-dev",
  "private": false,
  "version": "0.3.0",
  "description": "Local-first autonomous coding agent workspace built on Pi with dashboard, API, worker, and browser debugging workflows.",
  "keywords": [
    "pinchy",
    "coding-agent",
    "local-first",
    "pi",
    "playwright",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/pinchy-dev/pinchy-dev#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinchy-dev/pinchy-dev.git"
  },
  "bugs": {
    "url": "https://github.com/pinchy-dev/pinchy-dev/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "pinchy": "bin/pinchy.js"
  },
  "files": [
    "bin/",
    ".pi/",
    "apps/api/",
    "apps/dashboard/dist/",
    "apps/dashboard/index.html",
    "apps/dashboard/package.json",
    "apps/dashboard/src/",
    "apps/dashboard/vite.config.ts",
    "apps/host/src/",
    "apps/desktop/README.md",
    "apps/web/README.md",
    "packages/",
    "services/",
    "scripts/",
    "README.md",
    "docs/",
    "LICENSE"
  ],
  "scripts": {
    "pinchy": "node bin/pinchy.js",
    "agent": "tsx apps/host/src/main.ts",
    "daemon": "tsx apps/host/src/pinchy-daemon.ts",
    "dashboard": "tsx apps/host/src/dashboard.ts",
    "dashboard:web": "vite --config apps/dashboard/vite.config.ts",
    "dashboard:build": "vite build --config apps/dashboard/vite.config.ts",
    "dashboard:smoke": "tsx scripts/dashboard-smoke.ts",
    "pinchy:install-smoke": "tsx scripts/pinchy-install-smoke.ts",
    "playwright:install": "playwright install chromium",
    "api": "tsx apps/api/src/server.ts",
    "worker": "tsx services/agent-worker/src/worker.ts",
    "up": "tsx apps/host/src/up.ts",
    "check": "tsc --noEmit",
    "test": "for test_file in tests/*.test.ts; do node --import tsx --test \"$test_file\" || exit 1; done",
    "release:verify": "tsx scripts/release-verify.ts",
    "bootstrap": "bash scripts/bootstrap.sh"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@sinclair/typebox": "^0.34.41",
    "@tailwindcss/vite": "^4.1.12",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "playwright": "^1.54.2",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.8"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.2",
    "vite": "^6.4.2"
  }
}
